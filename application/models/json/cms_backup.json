{
    "table": "cms_backup",
    "cms": {
        "order": "!date",
        "label": "Backup restore",
        "disable": [
            "add",
            "remove",
            "backup"
        ],
        "buttons_edit": [
            {
                "label": "Restore record",
                "icon": "restore",
                "plugin": "cms_backup_restore"
            }
        ],
        "buttons_page": [
            {
                "label": "Backup Media",
                "hidden":true,
                "icon": "backup",
                "type": "page",
                "page": "cms_backup_media?s_page={{get.s_page}}&s_record={{get.s_record}}"
            }
        ]
    },
    "fields": [
        {
            "field": "date",
            "type": "timestamp",
            "cms": {
                "label": "Date",
                "list": "show",
                "edit": false
            }
        },
        {
            "field": "session",
            "cms": {
                "label": "Session",
                "list": "show",
                "edit": false
            },
            "type": "select",
            "source": {
                "model": "cms_users_logs_logins"
            }
        },
        {
            "field": "page",
            "cms": {
                "label_PL": "Strona",
                "label_EN": "Page",
                "list": "show",
                "edit": false,
                "search": "strict"
            }
        },
        {
            "field": "record",
            "cms": {
                "label": "Record",
                "list": "show",
                "edit": false,
                "search": true
            }
        },
        {
            "field": "data",
            "type": "json",
            "cms": {
                "label": "Data",
                "edit": false
            }
        }
    ]
}